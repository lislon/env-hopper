# Database - PostgreSQL
EH_CORE_DATABASE_URL="postgres://..."

# Server
NODE_ENV=development
PORT=4001

# AI Provider - OpenAI (required for admin chat)
OPENAI_API_KEY=

# Better Auth Configuration
# Required: Authentication secret (minimum 32 characters)
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=dev-secret-change-in-production-minimum-32-chars!

# Base URL for auth callbacks (should match frontend URL)
BETTER_AUTH_URL=http://localhost:4000

# OAuth Providers - GitHub (optional)
# Get credentials from: https://github.com/settings/developers
# AUTH_GITHUB_CLIENT_ID=your_github_client_id
# AUTH_GITHUB_CLIENT_SECRET=your_github_client_secret

# OAuth Providers - Google (optional)
# Get credentials from: https://console.cloud.google.com
# AUTH_GOOGLE_CLIENT_ID=your_google_client_id
# AUTH_GOOGLE_CLIENT_SECRET=your_google_client_secret

# OAuth Providers - Okta (optional)
# AUTH_OKTA_CLIENT_ID=your_okta_client_id
# AUTH_OKTA_CLIENT_SECRET=your_okta_client_secret
# AUTH_OKTA_ISSUER=https://your-org.okta.com
