{
  "name": "@env-hopper/backend-api",
  "version": "0.1.0",
  "description": "Backend API library for Env Hopper",
  "homepage": "https://github.com/lislon/env-hopper",
  "repository": {
    "type": "git",
    "url": "https://github.com/lislon/env-hopper.git",
    "directory": "packages/backend-api"
  },
  "license": "MIT",
  "author": "Igor Golovin",
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/esm/index.d.ts",
        "default": "./dist/esm/index.js"
      },
      "require": {
        "types": "./dist/cjs/index.d.cts",
        "default": "./dist/cjs/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "main": "dist/cjs/index.cjs",
  "module": "dist/esm/index.js",
  "types": "dist/esm/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "vite build",
    "clean": "rimraf ./dist && rimraf ./coverage",
    "test:eslint": "eslint ./src",
    "test:unit": "vitest",
    "test:unit:dev": "pnpm run test:unit --watch --hideSkippedTests",
    "test:build": "publint --strict && attw --ignore-rules no-resolution --pack ."
  },
  "dependencies": {},
  "devDependencies": {},
  "engines": {
    "node": ">=16"
  }
}
