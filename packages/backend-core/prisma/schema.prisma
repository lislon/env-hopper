// Prisma schema for backend-core library
// Uses EH_CORE_DATABASE_URL environment variable

datasource db {
  provider = "postgresql"
  url      = env("EH_CORE_DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

generator json {
  provider = "prisma-json-types-generator"
}

// ========== Better Auth Models ==========
model user {
  id            String    @id
  name          String?
  email         String?   @unique
  emailVerified Boolean   @default(false)
  image         String?
  role          String    @default("user") // 'user' | 'admin'
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  accounts      account[]
  sessions      session[]
}

model session {
  id        String   @id
  token     String   @unique
  userId    String
  user      user     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model account {
  id                    String    @id
  userId                String
  user                  user      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountId             String
  providerId            String
  refreshToken          String?
  accessToken           String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  idToken               String?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@unique([providerId, accountId])
}

model verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([identifier, value])
}

// ========== EnvHopper Models ==========

enum ApprovalMethodType {
  service
  personTeam
  custom
}

model DbApprovalMethod {
  slug        String             @id
  type        ApprovalMethodType
  displayName String
  /// [ApprovalMethodConfig] - Type-specific configuration
  config      Json?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@unique([type, displayName])
}

model DbAppForCatalog {
  id            String   @id @default(cuid())
  slug          String   @unique // URL-friendly identifier for navigation
  displayName   String
  description   String
  /// [AccessMethod]
  access        Json?
  teams         String[] @default([])
  /// [AppAccessRequest] - Per-app approval configuration linking to ApprovalMethod
  accessRequest Json?
  notes         String?
  tags          String[] @default([])
  appUrl        String?
  /// [AppLink[]]
  links         Json? // Array of {displayName?: string, url: string}
  iconName      String? // Optional icon identifier matching DbAsset.name
  screenshotIds String[] @default([]) // Ordered array of DbAsset IDs
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([displayName])
  @@index([slug])
  @@index([tags])
}

model DbAppTagDefinition {
  id          String   @id @default(cuid())
  prefix      String   @unique
  displayName String
  description String
  /// [GroupingTagValue[]]
  values      Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum AssetType {
  icon
  screenshot
}

model DbAsset {
  id        String    @id @default(cuid())
  name      String    @unique // Name with extension (e.g., "jira.svg", "github.png")
  assetType AssetType @default(icon)
  content   Bytes // Binary storage for all asset types (SVG, PNG, etc)
  checksum  String // SHA-256 of content for deduplication
  mimeType  String // e.g., "image/svg+xml", "image/png", "image/jpeg"
  fileSize  Int // Size in bytes
  width     Int? // Image width in pixels
  height    Int? // Image height in pixels
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([name])
  @@index([assetType])
}
