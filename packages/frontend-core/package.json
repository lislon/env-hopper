      "import": {
        "types": "./dist/esm/index.d.ts",
        "default": "./dist/esm/index.js"
      }
    },
    "./public": {
      "my-custom-condition": "./public",
      "default": "./dist/public"
    },
    "./index.css": {
      "my-custom-condition": "./src/index.css",
      "default": "./dist/index.css"
    },
    "./src/index.css": "./src/index.css",
    "./package.json": "./package.json"
  },
